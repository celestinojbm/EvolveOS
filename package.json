{
  "name": "evolveos",
  "version": "0.1.0",
  "private": true,
  "description": "EvolveOS monorepo — Phase 0 scaffold (issue #5). No product features yet.",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm --filter @evolveos/app dev",
    "build": "pnpm --filter @evolveos/app build",
    "test": "pnpm --filter @evolveos/app test",
    "typegen": "node ops/typegen.mjs",
    "migrate": "node ops/migrate.mjs",
    "check:eventlog": "node ops/check-single-writer.mjs",
    "check:gates": "node ops/check-gate-bypass.mjs",
    "check:dr": "node ops/check-dr-writer.mjs",
    "check:ratification": "node ops/check-ratification-writer.mjs",
    "check:stop": "node ops/check-stop-writer.mjs",
    "check:audit": "./app/node_modules/.bin/tsx ops/check-audit-conventions.ts",
    "audit:log": "./app/node_modules/.bin/tsx ops/verify-log.ts",
    "verify:events": "./app/node_modules/.bin/tsx ops/verify-log.ts verify",
    "db:up": "docker compose -f ops/docker-compose.yml up -d",
    "db:down": "docker compose -f ops/docker-compose.yml down -v"
  },
  "devDependencies": {
    "json-schema-to-typescript": "^15.0.4",
    "pg": "^8.13.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
