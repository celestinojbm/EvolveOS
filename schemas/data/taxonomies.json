{
  "version": "0.1.0",
  "source": "spec/ (Parts 0, VI, X, Appendix C)",
  "taxonomies": {
    "reversibility_classes": [
      {
        "id": "R1",
        "name": "Trivially reversible",
        "description": "Undo ≤ 1 hour of work and ≤ $1,000 cost; no external party affected",
        "source_markdown_reference": "spec/00-overview.md#5",
        "normative_status": "constitutional"
      },
      {
        "id": "R2",
        "name": "Reversible with effort",
        "description": "Undo ≤ 30 days and ≤ $50,000; no binding external commitments; no public exposure",
        "source_markdown_reference": "spec/00-overview.md#5",
        "normative_status": "constitutional"
      },
      {
        "id": "R3",
        "name": "Costly to reverse",
        "description": "Binding external commitments, public/brand exposure, contracts, spend $50k–$1M, individual hiring offers",
        "source_markdown_reference": "spec/00-overview.md#5",
        "normative_status": "constitutional"
      },
      {
        "id": "R4",
        "name": "Irreversible / existential",
        "description": "Cannot be meaningfully undone, or failure threatens the portfolio",
        "source_markdown_reference": "spec/00-overview.md#5",
        "normative_status": "constitutional"
      }
    ],
    "autonomy_levels": [
      {
        "id": "A0",
        "name": "Advisory",
        "description": "Agent analyses and recommends; a human performs the action",
        "source_markdown_reference": "spec/00-overview.md#6",
        "normative_status": "constitutional"
      },
      {
        "id": "A1",
        "name": "Human-in-the-loop",
        "description": "Agent prepares the complete action; a named human approves each execution before it happens",
        "source_markdown_reference": "spec/00-overview.md#6",
        "normative_status": "constitutional"
      },
      {
        "id": "A2",
        "name": "Human-on-the-loop",
        "description": "Agent executes within a pre-approved envelope; exceptions queue for human approval; humans review batches on a fixed cadence (≤ weekly)",
        "source_markdown_reference": "spec/00-overview.md#6",
        "normative_status": "constitutional"
      },
      {
        "id": "A3",
        "name": "Supervised autonomous",
        "description": "Agent executes and adapts tactics within a policy envelope; automatic circuit breakers; humans audit post-hoc via sampling",
        "source_markdown_reference": "spec/00-overview.md#6",
        "normative_status": "constitutional"
      },
      {
        "id": "A4",
        "name": "Fully autonomous",
        "description": "Agent executes, adapts, and modifies its own tactics; post-hoc audit only. Permitted only for R1 actions",
        "source_markdown_reference": "spec/00-overview.md#6",
        "normative_status": "constitutional"
      }
    ],
