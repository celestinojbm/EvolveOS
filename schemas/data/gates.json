{
  "version": "0.1.0",
  "source": "spec/appendix-c-decision-gates.md",
  "gates": [
    {
      "id": "G-00",
      "name": "Emergency Stop",
      "section": "standing",
      "trigger_or_transition": "Any authorized human, any Watchdog, or `PRIME` invokes halt on an agent, venture, or the whole system",
      "reversibility_class": "control",
      "reversibility_raw": "Control action (always available)",
      "decision_inputs": "Triggering evidence",
      "approver_body": "Any single authorized human (uni-directional: stopping never needs quorum; re-starting needs the owning gate's approver)",
      "human_approval_required": true,
      "mandatory_kill_criteria_required": false,
      "sla_or_envelope": "Immediate",
      "implemented_status": "planned",
      "source_markdown_reference": "spec/appendix-c-decision-gates.md"
    },
    {
      "id": "G-01",
      "name": "Opportunity Intake",
      "section": "pipeline",
      "trigger_or_transition": "Discovery → Trend Analysis/Research",
      "reversibility_class": "R1",
      "reversibility_raw": "R1",
      "decision_inputs": "Opportunity brief with source provenance",
      "approver_body": "`PORTFOLIO` (A3, auto)",
      "human_approval_required": false,
      "mandatory_kill_criteria_required": true,
      "sla_or_envelope": "Research budget ≤ $2k",
      "implemented_status": "planned",
      "source_markdown_reference": "spec/appendix-c-decision-gates.md"
    },
    {
      "id": "G-02",
      "name": "Research Commit",
      "section": "pipeline",
      "trigger_or_transition": "Research → Validation",
      "reversibility_class": "R2",
      "reversibility_raw": "R1/R2",
      "decision_inputs": "Research dossier, initial market sizing",
      "approver_body": "`PORTFOLIO` (A3 ≤ $10k; above queues A2)",
      "human_approval_required": false,
      "mandatory_kill_criteria_required": true,
      "sla_or_envelope": "Validation budget ≤ $10k",
      "implemented_status": "planned",
      "source_markdown_reference": "spec/appendix-c-decision-gates.md"
    },
    {
      "id": "G-03",
      "name": "Validation Verdict",
      "section": "pipeline",
      "trigger_or_transition": "Validation → Customer Discovery (or Kill)",
      "reversibility_class": "R2",
      "reversibility_raw": "R2",
      "decision_inputs": "Validation results vs. pre-registered kill criteria, DR",
      "approver_body": "`PORTFOLIO` (A2) with weekly human IC-delegate review of the batch",
      "human_approval_required": true,
      "mandatory_kill_criteria_required": true,
      "sla_or_envelope": "Discovery budget ≤ $15k",
      "implemented_status": "planned",
      "source_markdown_reference": "spec/appendix-c-decision-gates.md"
    },
    {
      "id": "G-04",
      "name": "Prototype Commit",
      "section": "pipeline",
      "trigger_or_transition": "Customer Discovery/Competitive/Modeling/Risk/Legal analyses → Prototype",
      "reversibility_class": "R2",
      "reversibility_raw": "R2",
      "decision_inputs": "Full analysis pack (Stages 5–9 outputs), DR",
      "approver_body": "`PORTFOLIO` (A2)",
      "human_approval_required": true,
      "mandatory_kill_criteria_required": true,
      "sla_or_envelope": "Prototype budget ≤ $25k",
      "implemented_status": "planned",
      "source_markdown_reference": "spec/appendix-c-decision-gates.md"
    },
    {
      "id": "G-05",
      "name": "MVP Commit",
      "section": "pipeline",
      "trigger_or_transition": "Prototype → MVP",
      "reversibility_class": "R3",
      "reversibility_raw": "R3",
      "decision_inputs": "Prototype evidence, updated model, kill criteria for MVP",
      "approver_body": "Named human: Portfolio Review lead (A1), weekly cadence",
      "human_approval_required": true,
      "mandatory_kill_criteria_required": true,
      "sla_or_envelope": "MVP budget ≤ $150k",
      "implemented_status": "planned",
      "source_markdown_reference": "spec/appendix-c-decision-gates.md"
    },
    {
      "id": "G-06",
      "name": "Launch / GTM",
      "section": "pipeline",
      "trigger_or_transition": "MVP → PMF search (public launch, paid acquisition beyond tests)",
      "reversibility_class": "R3",
      "reversibility_raw": "R3",
      "decision_inputs": "Launch readiness checklist (QA, security, legal, support), GTM plan",
      "approver_body": "Named human: Portfolio Review lead + G-17 for public comms",
      "human_approval_required": true,
      "mandatory_kill_criteria_required": true,
      "sla_or_envelope": "GTM budget ≤ $100k/quarter",
      "implemented_status": "planned",
      "source_markdown_reference": "spec/appendix-c-decision-gates.md"
    },
    {
      "id": "G-07",
      "name": "Venture Formation & Seed",
      "section": "pipeline",
      "trigger_or_transition": "PMF evidence → separate legal entity + seed allocation",
      "reversibility_class": "R4",
      "reversibility_raw": "R4",
      "decision_inputs": "PMF evidence pack, 18-month plan, entity structure memo (GC), DR",
      "approver_body": "IC quorum (≥3) + GC",
      "human_approval_required": true,
      "mandatory_kill_criteria_required": true,
      "sla_or_envelope": "Seed ≤ $1M; entity formed",
      "implemented_status": "deferred",
      "source_markdown_reference": "spec/appendix-c-decision-gates.md"
    },
    {
      "id": "G-08",
      "name": "Scale Funding",
      "section": "pipeline",
      "trigger_or_transition": "Internal series (growth capital tranche)",
      "reversibility_class": "R4",
      "reversibility_raw": "R4",
      "decision_inputs": "Cohort economics, capacity plan, updated valuation",
      "approver_body": "IC quorum + CFO",
      "human_approval_required": true,
      "mandatory_kill_criteria_required": true,
      "sla_or_envelope": "Tranche per IC resolution",
      "implemented_status": "deferred",
      "source_markdown_reference": "spec/appendix-c-decision-gates.md"
    },
    {
      "id": "G-09",
      "name": "Hiring",
      "section": "pipeline",
      "trigger_or_transition": "Hiring plan (R3); each individual offer (R3); executive hires (R4)",
      "reversibility_class": "R4",
      "reversibility_raw": "R3/R4",
      "decision_inputs": "Role case, comp banding, budget check",
      "approver_body": "Plan/offers: Head of People + hiring manager (human); exec: EC",
      "human_approval_required": true,
      "mandatory_kill_criteria_required": true,
      "sla_or_envelope": "Headcount per plan",
      "implemented_status": "deferred",
      "source_markdown_reference": "spec/appendix-c-decision-gates.md"
    },
    {
      "id": "G-10",
      "name": "Major Commitment",
      "section": "pipeline",
      "trigger_or_transition": "Any single contract/partnership > $100k total value or > 12 months term",
      "reversibility_class": "R3",
      "reversibility_raw": "R3",
      "decision_inputs": "`CONTRACTS` review, counterparty risk check",
      "approver_body": "Named human budget owner + GC delegate",
      "human_approval_required": true,
      "mandatory_kill_criteria_required": true,
      "sla_or_envelope": "Per contract",
      "implemented_status": "deferred",
      "source_markdown_reference": "spec/appendix-c-decision-gates.md"
    },
    {
      "id": "G-11",
      "name": "New Jurisdiction",
      "section": "pipeline",
      "trigger_or_transition": "Internationalization: operating/selling into a new legal jurisdiction",
      "reversibility_class": "R4",
      "reversibility_raw": "R4",
      "decision_inputs": "Regulatory map (`REG-WATCH`), tax/entity memo, localized compliance plan",
      "approver_body": "IC + GC",
      "human_approval_required": true,
      "mandatory_kill_criteria_required": true,
      "sla_or_envelope": "Per expansion plan",
      "implemented_status": "deferred",
      "source_markdown_reference": "spec/appendix-c-decision-gates.md"
    },
    {
      "id": "G-12",
      "name": "Acquisition",
      "section": "pipeline",
      "trigger_or_transition": "LOI issuance; separately, deal close",
      "reversibility_class": "R4",
      "reversibility_raw": "R4",
      "decision_inputs": "Valuation (`MNA-ANALYST`), DD pack, integration plan, financing plan",
      "approver_body": "LOI: IC quorum; Close: Board majority",
      "human_approval_required": true,
      "mandatory_kill_criteria_required": true,
      "sla_or_envelope": "Per resolution",
      "implemented_status": "deferred",
      "source_markdown_reference": "spec/appendix-c-decision-gates.md"
    },
    {
      "id": "G-13",
      "name": "Merger / Restructuring",
      "section": "pipeline",
      "trigger_or_transition": "Merging ventures, spin-outs, material reorg, any layoff/RIF",
      "reversibility_class": "R4",
      "reversibility_raw": "R4",
      "decision_inputs": "Rationale DR, people impact plan, legal memo",
      "approver_body": "Board majority; layoffs additionally require CEO + Head of People + GC",
      "human_approval_required": true,
      "mandatory_kill_criteria_required": true,
      "sla_or_envelope": "Per resolution",
      "implemented_status": "deferred",
      "source_markdown_reference": "spec/appendix-c-decision-gates.md"
    },
    {
      "id": "G-14",
      "name": "Exit",
      "section": "pipeline",
      "trigger_or_transition": "Sale of a venture, IPO process start",
      "reversibility_class": "R4",
      "reversibility_raw": "R4",
      "decision_inputs": "Banker/valuation analysis, tax memo, board deck",
      "approver_body": "Board majority",
      "human_approval_required": true,
      "mandatory_kill_criteria_required": true,
      "sla_or_envelope": "Per resolution",
      "implemented_status": "deferred",
      "source_markdown_reference": "spec/appendix-c-decision-gates.md"
    },
    {
      "id": "G-15",
      "name": "Shutdown",
      "section": "pipeline",
      "trigger_or_transition": "Venture wind-down and dissolution",
      "reversibility_class": "R4",
      "reversibility_raw": "R4",
      "decision_inputs": "Post-mortem draft, customer/creditor obligations plan, data disposition plan",
      "approver_body": "IC quorum; entity dissolution adds GC",
      "human_approval_required": true,
      "mandatory_kill_criteria_required": true,
      "sla_or_envelope": "Wind-down budget",
      "implemented_status": "deferred",
      "source_markdown_reference": "spec/appendix-c-decision-gates.md"
    },
    {
      "id": "G-16",
      "name": "Constitutional Change",
      "section": "standing",
      "trigger_or_transition": "Any modification to Parts 0/X/XI/Appendix C, any autonomy-ceiling change, any change to Kernel enforcement rules",
      "reversibility_class": "R4",
      "reversibility_raw": "R4",
      "decision_inputs": "Evolution proposal (EP), impact analysis, rollback plan, red-team review",
      "approver_body": "TSC quorum (≥3 humans) + CEO sign-off",
      "human_approval_required": true,
      "mandatory_kill_criteria_required": false,
      "sla_or_envelope": "≤ 14 days",
      "implemented_status": "deferred",
      "source_markdown_reference": "spec/appendix-c-decision-gates.md"
    },
    {
      "id": "G-17",
      "name": "Public Communication",
      "section": "standing",
      "trigger_or_transition": "Brand/PR statements, public launches announcements, social posts beyond pre-approved templates, press interaction",
      "reversibility_class": "R3",
      "reversibility_raw": "R3",
      "decision_inputs": "Draft, audience, risk note",
      "approver_body": "Named human comms owner (A1)",
      "human_approval_required": true,
      "mandatory_kill_criteria_required": false,
      "sla_or_envelope": "≤ 24 h",
      "implemented_status": "planned",
      "source_markdown_reference": "spec/appendix-c-decision-gates.md"
    },
    {
      "id": "G-18",
      "name": "Data Use Expansion",
      "section": "standing",
      "trigger_or_transition": "Any use of personal or customer data outside its approved classification/purpose; new data acquisition sources",
      "reversibility_class": "R3",
      "reversibility_raw": "R3",
      "decision_inputs": "Privacy review by `PRIVACY`, legal note",
      "approver_body": "GC or delegated privacy officer",
      "human_approval_required": true,
      "mandatory_kill_criteria_required": false,
      "sla_or_envelope": "≤ 5 days",
      "implemented_status": "planned",
      "source_markdown_reference": "spec/appendix-c-decision-gates.md"
    }
  ]
}
