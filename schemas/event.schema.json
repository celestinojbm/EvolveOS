{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://evolveos.spec/schemas/event.schema.json",
  "title": "EvolveOS append-only event",
  "version": "0.1.0",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "timestamp", "actor_type", "actor_id", "event_type", "hash"],
  "properties": {
    "id": {"type": "string", "minLength": 1},
    "timestamp": {"type": "string", "minLength": 1},
    "actor_type": {"type": "string", "enum": ["human", "agent", "kernel", "watchdog", "system"]},
    "actor_id": {"type": "string", "minLength": 1},
    "event_type": {"type": "string", "minLength": 1},
    "object_type": {"type": ["string", "null"]},
    "object_id": {"type": ["string", "null"]},
    "payload": {"type": ["object", "null"]},
    "previous_hash": {"type": ["string", "null"]},
    "hash": {"type": "string", "minLength": 1},
    "trace_id": {"type": ["string", "null"]}
  }
}
